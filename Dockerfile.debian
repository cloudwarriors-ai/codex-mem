FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    dnsutils \
    git \
    iproute2 \
    iputils-ping \
    jq \
    less \
    lsof \
    nano \
    netcat-openbsd \
    procps \
    sqlite3 \
    strace \
    tini \
    vim-tiny \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY docker/entrypoint.sh /usr/local/bin/codex-mem-entrypoint
RUN chmod +x /usr/local/bin/codex-mem-entrypoint

ENV CODEX_HOME=/root/.codex
ENV NODE_ENV=development

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/codex-mem-entrypoint"]
CMD ["bash"]
