{
  "name": "codex-mem",
  "version": "0.1.1",
  "description": "Persistent memory system for Codex sessions with SQLite + FTS5 + MCP tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codex-mem": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/dashboard/client && cp -R src/dashboard/client/* dist/dashboard/client/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codex",
    "memory",
    "mcp",
    "sqlite",
    "fts"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
